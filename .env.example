# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side admin key — use ONE of these:
# Legacy dashboard: service_role JWT key
SUPABASE_SERVICE_ROLE_KEY=
# New dashboard: secret key (sb_secret_...)
SUPABASE_SECRET_KEY=

# Optional aliases (new Supabase key format)
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_PUBLISHABLE_KEY=

# OpenAI (server-side only — never expose to frontend)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# Optional webhook integrations (n8n, Make, Zapier)
N8N_WEBHOOK_URL=
MAKE_WEBHOOK_URL=
ZAPIER_WEBHOOK_URL=

# Webhook signature (placeholder — set in production)
WEBHOOK_SIGNING_SECRET=

# Optional admin protection (future use)
ADMIN_API_SECRET=

# Platform admin (used by npm run seed:admin — do not commit real passwords)
PLATFORM_ADMIN_EMAIL=admin@raianvisual
PLATFORM_ADMIN_PASSWORD=
PLATFORM_ADMIN_NAME=Raian Visual Admin
